
<html>
  <head>
    <meta charset="UTF-8">
    <title>AndesNet Soluciones Tecnológicas</title>
    <style>
      body {
        margin: 0;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        background: linear-gradient(to bottom, #1e3d59, #f5f5f5);
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 100vh;
        text-align: center;
      }

      .container {
